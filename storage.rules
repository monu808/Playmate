rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Auth helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isAuthenticated() &&
             exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    // Role helpers
    function isAdmin() {
      return hasUserDoc() &&
             get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner() {
      return hasUserDoc() &&
             get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function isAdminOrOwner() {
      return isAdmin() || isOwner();
    }

    // File validation helpers
    function isValidImage(maxBytes) {
      return request.resource != null &&
             request.resource.size < maxBytes &&
             request.resource.contentType != null &&
             request.resource.contentType.matches('image/.*');
    }

    // Profile images: user can manage own files, admin can manage any
    match /profiles/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isAuthenticated() &&
                              (request.auth.uid == userId || isAdmin()) &&
                              isValidImage(5 * 1024 * 1024); // Max 5MB
      allow delete: if isAuthenticated() &&
                      (request.auth.uid == userId || isAdmin());
    }

    // Preferred turf image path: /turfs/{ownerId}/...
    match /turfs/{ownerId}/{allImages=**} {
      allow read: if true;
      allow create, update: if isAuthenticated() &&
                              (request.auth.uid == ownerId || isAdmin()) &&
                              isValidImage(10 * 1024 * 1024); // Max 10MB
      allow delete: if isAuthenticated() &&
                      (request.auth.uid == ownerId || isAdmin());
    }

    // Backward-compatible turf image path fallback: /turfs/...
    // Restrict to owner/admin only (not general users).
    match /turfs/{allImages=**} {
      allow read: if true;
      allow create, update: if isAuthenticated() &&
                              isAdminOrOwner() &&
                              isValidImage(10 * 1024 * 1024);
      allow delete: if isAuthenticated() &&
                      isAdminOrOwner();
    }

    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
